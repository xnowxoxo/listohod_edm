DATABASE_URL=postgresql://listohod:listohod_secret@localhost:5432/listohod
JWT_SECRET=super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d
PORT=3001
NODE_ENV=development

# Storage: 'local' (default) or 's3'
STORAGE_DRIVER=local

# Local storage (used when STORAGE_DRIVER=local)
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# S3-compatible storage (used when STORAGE_DRIVER=s3)
# Compatible with AWS S3, Cloudflare R2, MinIO, etc.
S3_BUCKET=
S3_REGION=auto
S3_ENDPOINT=         # e.g. https://<accountid>.r2.cloudflarestorage.com (leave empty for AWS S3)
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_URL=       # e.g. https://files.example.com (optional, for public bucket URL in att.url field)
